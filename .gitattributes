# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Rust source files
*.rs text eol=lf
*.toml text eol=lf
Cargo.lock text eol=lf

# Web / Frontend files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell and script files
*.sh text eol=lf
*.ps1 text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Tauri specific
tauri.conf.json text eol=lf
*.config text eol=lf

# Git config files
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files (images, fonts, executables, installers)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Compiled / Package binaries
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.AppImage binary
*.deb binary
*.rpm binary
*.dmg binary
*.zip binary
*.tar.gz binary
*.tar.xz binary
*.7z binary
*.pdf binary
