{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "PyPDFSeal",
  "version": "0.1.3",
  "identifier": "com.pydfseal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PyPDFSeal",
        "width": 1300,
        "height": 850,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFQkEwNEFEMTJCQzg5RjAKUldUd2lid1NyUVM2TG5iQW84RUkxTGRPOCtCZGdJQmRqOUtISXlLakVwWXg0WkM2OWFHeTNQM0YK",
      "endpoints": [
        "https://github.com/CarryDream/PyPDFSeal/releases/latest/download/latest.json"
      ]
    }
  }
}
